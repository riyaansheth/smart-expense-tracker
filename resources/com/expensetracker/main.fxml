<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="rootPane"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.expensetracker.controller.MainController"
            styleClass="root-pane">

    <!-- TOP BAR -->
    <top>
        <HBox fx:id="topBar" alignment="CENTER_LEFT" spacing="20"
              styleClass="top-bar">
            <Label text="EXPENSE CONTROL — CHAYYA STORE"
                   styleClass="title-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER_RIGHT" spacing="3">
                <Label fx:id="balanceLabel" text="Balance: ₹ 0.00"
                       styleClass="balance-label"/>
                <HBox spacing="20">
                    <Label fx:id="totalIncomeLabel" text="Income: ₹ 0.00 (0)"
                           styleClass="info-label"/>
                    <Label fx:id="totalExpenseLabel" text="Expenses: ₹ 0.00 (0)"
                           styleClass="info-label"/>
                    <Label fx:id="countLabel" text="Total Transactions: 0"
                           styleClass="info-label"/>
                </HBox>
            </VBox>
            <Button fx:id="darkModeButton" text="🌙  Dark Mode" onAction="#handleToggleDarkMode"
                    styleClass="action-button toggle-button"/>
        </HBox>
    </top>

    <!-- LEFT PANEL — Transaction Form -->
    <left>
        <VBox fx:id="leftPanel" spacing="10" minWidth="240" maxWidth="255"
              styleClass="side-card left-panel-glow">
            <padding><Insets top="18" right="14" bottom="18" left="14"/></padding>

            <Label text="Transaction Form"
                   styleClass="panel-heading"/>
            <Separator/>

            <Label text="Amount (₹) *" styleClass="panel-subtitle"/>
            <TextField fx:id="amountField" promptText="e.g. 1500.00"
                       styleClass="text-input"/>

            <Label text="Category *" styleClass="panel-subtitle"/>
            <TextField fx:id="categoryField" promptText="e.g. Groceries"
                       styleClass="text-input"/>

            <Label text="Date *" styleClass="panel-subtitle"/>
            <DatePicker fx:id="datePicker" maxWidth="Infinity" styleClass="date-picker"/>

            <Label text="Type *" styleClass="panel-subtitle"/>
            <ComboBox fx:id="typeCombo" maxWidth="Infinity" styleClass="combo-box"/>

            <Label text="Notes (optional)" styleClass="panel-subtitle"/>
            <TextField fx:id="notesField" promptText="Any extra detail..."
                       styleClass="text-input"/>

            <Separator/>

            <Button text="Add Income" onAction="#handleAddIncome" maxWidth="Infinity"
                    styleClass="action-button primary-button"/>
            <Button text="Add Expense" onAction="#handleAddExpense" maxWidth="Infinity"
                    styleClass="action-button danger-button"/>
            <Button text="Update Selected" onAction="#handleUpdate" maxWidth="Infinity"
                    styleClass="action-button warning-button"/>
            <Button text="Delete Selected" onAction="#handleDelete" maxWidth="Infinity"
                    styleClass="action-button danger-button"/>
            <Button text="Export to CSV" onAction="#handleExportCsv" maxWidth="Infinity"
                    styleClass="action-button accent-button"/>

            <Region VBox.vgrow="ALWAYS"/>
            <Separator/>
            <Label text="Click a row to load it for editing."
                   wrapText="true"
                   styleClass="panel-subtitle"/>
        </VBox>
    </left>

    <!-- CENTER — Search + Table -->
    <center>
        <VBox fx:id="centerContainer" spacing="0" styleClass="center-panel">

            <!-- Search / Filter Bar -->
            <VBox fx:id="searchBar" styleClass="filter-bar"
                  spacing="8">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="🔍 Filter" styleClass="panel-heading"/>
                    <ComboBox fx:id="searchTypeCombo" prefWidth="110" styleClass="combo-box"/>
                    <TextField fx:id="searchCategoryField" promptText="Category..." prefWidth="150"
                               styleClass="text-input"/>
                    <Label text="From:" styleClass="panel-subtitle"/>
                    <DatePicker fx:id="fromDatePicker" prefWidth="145" styleClass="date-picker"/>
                    <Label text="To:" styleClass="panel-subtitle"/>
                    <DatePicker fx:id="toDatePicker" prefWidth="145" styleClass="date-picker"/>
                    <Button text="Search" onAction="#handleSearch"
                            styleClass="action-button accent-button"/>
                    <Button text="Clear" onAction="#handleClearSearch"
                            styleClass="action-button warning-button"/>
                </HBox>
            </VBox>

            <!-- Transactions Table -->
            <VBox VBox.vgrow="ALWAYS" styleClass="section-block">
                <Label text="All Transactions  (click column headers to sort)"
                       styleClass="panel-heading"/>
                <TableView fx:id="transactionTable" VBox.vgrow="ALWAYS"
                           styleClass="data-table">
                    <columns>
                        <TableColumn fx:id="colId"       text="ID"         prefWidth="50"  sortable="true"/>
                        <TableColumn fx:id="colType"     text="Type"       prefWidth="90"  sortable="true"/>
                        <TableColumn fx:id="colAmount"   text="Amount (₹)" prefWidth="120" sortable="true"/>
                        <TableColumn fx:id="colCategory" text="Category"   prefWidth="150" sortable="true"/>
                        <TableColumn fx:id="colDate"     text="Date"       prefWidth="110" sortable="true"/>
                        <TableColumn fx:id="colNotes"    text="Notes"      prefWidth="200" sortable="false"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </VBox>
    </center>

    <!-- RIGHT PANEL — Summary + Monthly -->
    <right>
        <VBox fx:id="rightPanel" spacing="0" minWidth="220" maxWidth="240"
              styleClass="side-card right-panel-glow">

            <!-- Category Summary -->
            <VBox spacing="6" styleClass="panel-block">
                <Label text="Category Expenses"
                       styleClass="panel-heading"/>
                <Label text="With % breakdown"
                       styleClass="panel-subtitle"/>
                <Separator/>
                <ScrollPane fitToWidth="true" prefHeight="280"
                            styleClass="scroll-pane">
                    <VBox fx:id="summaryBox" spacing="8" styleClass="section-block"/>
                </ScrollPane>
            </VBox>

            <Separator/>

            <!-- Monthly Summary -->
            <VBox spacing="8" styleClass="panel-block-alt">
                <Label text="Monthly Summary"
                       styleClass="panel-heading"/>
                <Separator/>
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <ComboBox fx:id="monthCombo" prefWidth="115" styleClass="combo-box"/>
                    <ComboBox fx:id="yearCombo"  prefWidth="72" styleClass="combo-box"/>
                </HBox>
                <Button text="Show" onAction="#handleRefreshMonthly" maxWidth="Infinity"
                        styleClass="action-button accent-button"/>
                <Label fx:id="monthlyIncomeLabel"  text="Income:   ₹ 0.00"
                       styleClass="info-label"/>
                <Label fx:id="monthlyExpenseLabel" text="Expenses: ₹ 0.00"
                       styleClass="info-label"/>
                <Label fx:id="monthlyBalanceLabel" text="Net:      ₹ 0.00"
                       styleClass="balance-label"/>
            </VBox>
        </VBox>
    </right>

</BorderPane>
